# Supabase — user accounts and roles (required for auth)
# Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional — only needed for admin scripts (signup uses anon key + DB trigger)
# SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — required for two-phone demo sync on Vercel
# Add via: Vercel Dashboard → Storage → Upstash Redis → Connect to project
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional shared demo room (defaults to doorway-hackathon)
# DOORWAY_DEMO_ROOM=doorway-hackathon
