# Supabase — user accounts, roles, and passwords (required for auth)
# Passwords are stored hashed in Supabase Auth (auth.users), not in public.profiles.
# Dashboard → Project Settings → API Keys
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Paste your secret key from Supabase → API Keys → default (server-only, never NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=

# Upstash Redis — search cache + two-phone demo sync on Vercel
# Add via: Vercel Dashboard → Storage → Upstash Redis → Connect to project
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Bright Data Web Unlocker — unlocks Zillow rental search (Section 8 uses AffordableHousing.com direct)
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_UNLOCKER_ZONE=web_unlocker1

# Demo / hackathon mode (optional)
# ALLOW_DEMO_BYPASS=true — skip auth middleware + allow role switcher without login
# NEXT_PUBLIC_ALLOW_DEMO_BYPASS=true — same flag for client AuthGate
ALLOW_DEMO_BYPASS=true
NEXT_PUBLIC_ALLOW_DEMO_BYPASS=true

# Protect demo sync POST in production (set same value in Vercel for client header)
DEMO_SYNC_SECRET=
NEXT_PUBLIC_DEMO_SYNC_SECRET=

# Optional shared demo room (defaults to doorway-hackathon)
# DOORWAY_DEMO_ROOM=doorway-hackathon
