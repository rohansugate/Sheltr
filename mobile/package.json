{
  "name": "doorway-mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "ios": "expo run:ios --device",
    "ios:install": "bash scripts/install-iphone.sh",
    "ios:wait": "bash scripts/install-iphone.sh --wait",
    "ios:eas": "bash scripts/install-iphone.sh --eas",
    "xcode:install": "bash scripts/install-iphone.sh",
    "pod:install": "bash scripts/pod-install.sh",
    "eas:install": "bash scripts/eas-install-on-iphone.sh",
    "build:ios:dev": "eas build --profile development --platform ios",
    "android": "expo run:android"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.17",
    "expo-dev-client": "~56.0.19",
    "expo-linking": "~56.0.13",
    "expo-router": "~56.2.9",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-webview": "13.16.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eas-cli": "^20.1.0",
    "typescript": "~6.0.3"
  },
  "private": true
}
